# Google OAuth 2.0 credentials
# Get these from: https://console.cloud.google.com → APIs & Services → Credentials
# Enable the "Google Drive API" for your project first.
#
# Create 3 OAuth 2.0 Client IDs:
#   1. Web application          → EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID
#   2. iOS (bundle: com.feemovision.feemobudget)     → EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID
#   3. Android (package: com.feemovision.feemobudget) → EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID
#
# For Android you'll also need the SHA-1 fingerprint from:
#   eas credentials --platform android

EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=363901075945-ggc8jsi2uq10hr7ql2ltmqsqd39bs80v.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=363901075945-bdq65dtgjjphuoph3qd1e68r674r5vp4.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=363901075945-52t4ao4osj6oa2f2hc7ashov3o77nm3v.apps.googleusercontent.com

EXPO_PUBLIC_FIREBASE_API_KEY=REPLACE_WITH_FIREBASE_API_KEY
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=feemo-beta-functions.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=feemo-beta-functions
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=feemo-beta-functions.appspot.com
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=REPLACE_WITH_MESSAGING_SENDER_ID
EXPO_PUBLIC_FIREBASE_APP_ID=REPLACE_WITH_APP_ID
